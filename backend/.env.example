# Server
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# MongoDB
MONGODB_URI=mongodb://localhost:27017/visitoriq

# Redis (cache + BullMQ queues)
REDIS_URL=redis://localhost:6379

# --- IP-to-Company provider ---
# "cymru" = real ASN/org-name lookup via Team Cymru's free WHOIS service. No key,
#   no signup, no rate-limit tier — genuinely free. No domain field is returned, so
#   the provider slugifies the AS name into a best-effort ".com" guess.
# "ipinfo" = real ASN lookup (free-tier key from ipinfo.io, no card required).
# "mock" = fixture data, no key needed.
IP_TO_COMPANY_PROVIDER=cymru
IPINFO_API_TOKEN=

# --- Company detail enrichment (socials, industry, tech stack, logo) ---
# "own_dataset" = scrapes the resolved company's own public homepage. No key, no cost.
# "mock" = fixture data.
COMPANY_ENRICHMENT_PROVIDER=own_dataset

# --- Contact / decision-maker enrichment ---
# "own_dataset" (default) = scrapes the company's own Team/Leadership page + guesses
#   emails from the firstname.lastname@domain pattern. No key, no cost, unverified emails.
# "mock" = fixture data.
CONTACT_PROVIDER=own_dataset

# --- Alerts ---
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=alerts@visitoriq.local

# --- CRM integrations (mock-backed until real OAuth apps are registered) ---
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=

# --- Billing (mock-backed) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Enrichment cache TTL (seconds) - avoids re-scraping/re-calling for the same company
ENRICHMENT_CACHE_TTL_SECONDS=604800
