# Server
PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

# Auth
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# MongoDB
MONGODB_URI=mongodb://localhost:27017/visitoriq

# Redis (cache + BullMQ queues)
REDIS_URL=redis://localhost:6379

# --- IP-to-Company provider ---
# Set to "cymru" for free ASN/org lookups (Team Cymru WHOIS, no key), "ipinfo" for
# ipinfo.io lookups (needs IPINFO_API_TOKEN), or "mock" to use fixture data.
IP_TO_COMPANY_PROVIDER=cymru
IPINFO_API_TOKEN=bceec6db12f1df

# --- Company detail enrichment (socials, industry, tech stack, logo) ---
COMPANY_ENRICHMENT_PROVIDER=own_dataset

# --- Contact enrichment provider ---
# Set to "own_dataset" (scrapes the company's own team page, no key), or "mock".
CONTACT_PROVIDER=own_dataset

# --- Alerts ---
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL_FROM=alerts@visitoriq.local

# --- CRM integrations (mock-backed until real OAuth apps are registered) ---
HUBSPOT_CLIENT_ID=
HUBSPOT_CLIENT_SECRET=
SALESFORCE_CLIENT_ID=
SALESFORCE_CLIENT_SECRET=
PIPEDRIVE_CLIENT_ID=
PIPEDRIVE_CLIENT_SECRET=

# --- Billing (mock-backed) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Enrichment cache TTL (seconds) - avoids re-calling paid APIs for the same company
ENRICHMENT_CACHE_TTL_SECONDS=604800
